root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{ts,tsx,js,mjs,cjs,json,astro,css,md,yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4

[*.ps1]
end_of_line = crlf
indent_size = 2

[*.cmd]
end_of_line = crlf

[*.bat]
end_of_line = crlf

[Makefile]
indent_style = tab
